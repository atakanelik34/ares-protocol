{
  "name": "ares-protocol",
  "private": true,
  "version": "0.1.0",
  "description": "ARES Protocol monorepo",
  "workspaces": [
    "api/query-gateway",
    "api/scoring-service",
    "dashboard/agent-explorer",
    "sdk/typescript",
    "subgraph"
  ],
  "scripts": {
    "build": "npm run --workspaces build",
    "test": "npm run --workspaces test",
    "lint": "npm run --workspaces lint",
    "dev": "npm-run-all --parallel dev:*",
    "dev:query": "npm --workspace api/query-gateway run dev",
    "dev:scoring": "npm --workspace api/scoring-service run dev",
    "dev:agent-explorer": "npm --workspace dashboard/agent-explorer run dev",
    "contracts:bootstrap": "bash ./scripts/contracts/bootstrap.sh",
    "demo:seed:live": "npm --workspace api/scoring-service run seed:live",
    "demo:stream:actions": "npm --workspace api/scoring-service run stream:actions",
    "tokenomics:validate": "node ./scripts/tokenomics/calc-tokenomics.mjs",
    "deploy:contracts:sepolia": "bash ./deploy/contracts/deploy-base-sepolia.sh",
    "deploy:governance:proposal-smoke": "node ./deploy/contracts/governance-proposal-smoke-sepolia.mjs",
    "deploy:subgraph:sync": "node ./deploy/contracts/update-subgraph-addresses.mjs --addresses ./deploy/contracts/addresses.base-sepolia.json --manifest ./subgraph/subgraph.yaml --network base-sepolia",
    "deploy:addresses:refresh": "node ./deploy/contracts/refresh-addresses-from-latest.mjs",
    "demo:sepolia": "node ./deploy/contracts/run-demo-sepolia.mjs"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  },
  "engines": {
    "node": ">=22"
  }
}
