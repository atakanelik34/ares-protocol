{
  "name": "ares-protocol",
  "private": true,
  "version": "0.1.0",
  "description": "ARES Protocol monorepo",
  "workspaces": [
    "api/query-gateway",
    "api/scoring-service",
    "dashboard/agent-explorer",
    "dashboard/protocol-admin",
    "sdk/typescript",
    "subgraph"
  ],
  "scripts": {
    "build": "npm run --workspaces build",
    "test": "npm run --workspaces test",
    "lint": "npm run --workspaces lint",
    "dev": "npm-run-all --parallel dev:*",
    "dev:query": "npm --workspace api/query-gateway run dev",
    "dev:scoring": "npm --workspace api/scoring-service run dev",
    "dev:agent-explorer": "npm --workspace dashboard/agent-explorer run dev",
    "dev:protocol-admin": "npm --workspace dashboard/protocol-admin run dev"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  },
  "engines": {
    "node": ">=22"
  }
}
